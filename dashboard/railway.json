{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "dashboard/Dockerfile",
    "buildCommand": "echo 'Building dashboard with Supabase config...'"
