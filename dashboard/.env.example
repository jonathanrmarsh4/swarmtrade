# Dashboard environment variables
# Copy this file to .env.local for local development.
# On Railway, set these as service variables (not secrets — anon key is public).

# Supabase project URL — found in Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — safe to expose in the browser bundle.
# Do NOT use the service key here.
VITE_SUPABASE_ANON_KEY=your-anon-key-here
